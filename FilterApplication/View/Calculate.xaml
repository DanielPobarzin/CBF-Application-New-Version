<UserControl x:Class="FilterApplication.View.Calculate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Menu="clr-namespace:Application.Utilities;assembly=Application" xmlns:viewmodels="clr-namespace:ViewModels.ViewModels;assembly=ViewModels" xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation" d:DataContext="{d:DesignInstance Type=viewmodels:CalculateVM}"
             mc:Ignorable="d" 
             d:DesignHeight="600"
             d:DesignWidth="622"
              Style="{StaticResource Page_Style}">
    <UserControl.Resources>
        <Menu:RandomColorConverter x:Key="RandomColorConverter"/>
        <Menu:MultiCalculateConverter x:Key="MultiParameterConverter"/>
        <Style x:Key="TextBoxUniformStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FF11141A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Foreground" Value="#FFA6AAB4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#FF6E7073"/>
            <Setter Property="Padding" Value="10,0,0,0"/>
            <Setter Property="FontFamily" Value="/Resources/Fonts/#Raleway SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid x:Name="root" Height="{TemplateBinding Height}"
                             Width="{TemplateBinding Width}" 
                             SnapsToDevicePixels="True">
                            <Border x:Name="Background" 
                     BorderThickness="2" 
                     CornerRadius="10"
                     Background="{TemplateBinding Background}"
                     BorderBrush="{TemplateBinding BorderBrush}"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                           BorderThickness="0"
                           Padding="{TemplateBinding Padding}"
                           IsTabStop="False"
                           Background="{x:Null}"
                           TextElement.Foreground="{TemplateBinding Foreground}">

                            </ScrollViewer>

                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF383C44"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FF3D578C"/>
                                <Setter Property="Background" Value="#FF0E1116"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TextBlockForm" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="10, 10, 0, 0"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="MaxHeight" Value="80"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth" Value="350"/>
            <Setter Property="Foreground" Value="#DCE0E4"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontFamily" Value="/Resources/Fonts/#Raleway SemiBold"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <DataTemplate x:Key="AshCleanForFourFieldFilter">
            <Border x:Name="ExternalBorder" 
                    Margin="10" 
                    CornerRadius="25" 
                    Opacity="0.9" 
                    Background="Transparent"  
                    BorderThickness="4">
                <Border Background="#3A4149" Margin="3" CornerRadius="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.7*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" 
                                    Grid.ColumnSpan="2" 
                                    Orientation="Horizontal" 
                                    Margin="5 15 10 0" 
                                    VerticalAlignment="Top"  
                                    HorizontalAlignment="Stretch">
                                        <TextBlock TextAlignment="Left" 
                                       HorizontalAlignment="Left" 
                                       Foreground="#DCE0E4" 
                                       Text="Топливо: " 
                                       FontSize="12"
                                       FontStyle="Italic"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" 
                                       FontFamily="Century Gothic"/>
                                        <TextBlock Name="Fuel" 
                                       TextAlignment="Left" 
                                       HorizontalAlignment="Left" 
                                       Foreground="#DCE0E4" 
                                       FontSize="14"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap" 
                                       FontFamily="Century Gothic"/>
                                    </StackPanel>
                                <Border x:Name="InternalBorder" 
                                VerticalAlignment="Bottom" 
                                HorizontalAlignment="Stretch" 
                                Height="5" 
                                CornerRadius="2" 
                                Grid.Row="1" 
                                Grid.ColumnSpan="2" 
                                Margin="5 0 5 5">   
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0"/>
                                    <GradientStop Color="#3A4149" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Style="{StaticResource TextBlockForm}" 
                           Grid.Column="0" 
                           Grid.Row="2" 
                           Text="Для 1 поля:">
                        </TextBlock>
                        <TextBox Name="FirstField" Style="{StaticResource TextBoxUniformStyle}"
                     Grid.Column="2" Margin="10,5,10,5" IsReadOnly="True"
                     Grid.Row="2"/>

                        <TextBlock Style="{StaticResource TextBlockForm}" 
                       Grid.Column="0" 
                       Grid.Row="3" 
                       Text="Для 2 поля:">
                        </TextBlock>
                        <TextBox Name="SecondField" Style="{StaticResource TextBoxUniformStyle}"
                     Grid.Column="2" Margin="10,5,10,5" IsReadOnly="True"
                     Grid.Row="3"/>
                        <TextBlock Style="{StaticResource TextBlockForm}" 
                       Grid.Column="0" 
                       Grid.Row="4" 
                       Text="Для 3 поля:">
                        </TextBlock>
                        <TextBox Name="ThirdField" Style="{StaticResource TextBoxUniformStyle}"
                     Grid.Column="2" Margin="10,5,10,5" IsReadOnly="True"
                     Grid.Row="4"/>
                        <TextBlock Style="{StaticResource TextBlockForm}" 
                       Grid.Column="0" 
                       Grid.Row="5" 
                       Text="Для 4 поля:">
                        </TextBlock>
                        <TextBox Name="FourField" Style="{StaticResource TextBoxUniformStyle}"
                     Grid.Column="2" Margin="10,5,10,10" IsReadOnly="True"
                     Grid.Row="5"/>
                    </Grid>
                </Border>
                <Border.Effect>
                    <DropShadowEffect 
            Color="{Binding RelativeSource={RelativeSource AncestorType=Border}, 
            Path=BorderBrush.Color}"
            ShadowDepth="0"
            BlurRadius="20"
            Opacity="0.4"/>
                </Border.Effect>
            </Border>

        </DataTemplate>
        <DataTemplate x:Key="AshCleanForThreeFieldFilter">
            <Border x:Name="ExternalBorder" 
              Margin="10" 
              CornerRadius="25" 
              BorderBrush="{Binding RelativeSource={RelativeSource Self}, Converter={StaticResource RandomColorConverter}}" 
              Opacity="0.9" 
              Background="Transparent"  
              BorderThickness="4">
                <Border Background="#3A4149" Margin="3" CornerRadius="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.7*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" 
                              Grid.ColumnSpan="2" 
                              Orientation="Horizontal" 
                              Margin="5 15 10 0" 
                              VerticalAlignment="Top"  
                              HorizontalAlignment="Stretch">
                            <TextBlock TextAlignment="Left" 
                                 HorizontalAlignment="Left" 
                                 Foreground="#DCE0E4" 
                                 Text="Топливо: " 
                                 FontSize="12"
                                 FontStyle="Italic"
                                 FontWeight="Bold"
                                 TextWrapping="Wrap" 
                                 FontFamily="Century Gothic"/>
                            <TextBlock Name="Fuel" 
                                 TextAlignment="Left" 
                                 HorizontalAlignment="Left" 
                                 Foreground="#DCE0E4" 
                                 FontSize="14"
                                 FontStyle="Italic"
                                 TextWrapping="Wrap" 
                                 FontFamily="Century Gothic"/>
                        </StackPanel>
                        <Border x:Name="InternalBorder" 
                          VerticalAlignment="Bottom" 
                          HorizontalAlignment="Stretch" 
                          Height="5" 
                          CornerRadius="2" 
                          Grid.Row="1" 
                          Grid.ColumnSpan="2" 
                          Margin="5 0 5 5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0"/>
                                    <GradientStop Color="#3A4149" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Style="{StaticResource TextBlockForm}" 
                     Grid.Column="0" 
                     Grid.Row="2" 
                     Text="Для 1 поля:">
                        </TextBlock>
                        <TextBox Name="FirstField" Style="{StaticResource TextBoxUniformStyle}"
               Grid.Column="2" Margin="10,5,10,5" IsReadOnly="True"
               Grid.Row="2"/>

                        <TextBlock Style="{StaticResource TextBlockForm}" 
                 Grid.Column="0" 
                 Grid.Row="3" 
                 Text="Для 2 поля:">
                        </TextBlock>
                        <TextBox Name="SecondField" Style="{StaticResource TextBoxUniformStyle}"
               Grid.Column="2" Margin="10,5,10,5" IsReadOnly="True"
               Grid.Row="3"/>
                        <TextBlock Style="{StaticResource TextBlockForm}" 
                 Grid.Column="0" 
                 Grid.Row="4" 
                 Text="Для 3 поля:">
                        </TextBlock>
                        <TextBox Name="ThirdField" Style="{StaticResource TextBoxUniformStyle}"
                               Grid.Column="2" Margin="10,5,10,5" IsReadOnly="True"
                               Grid.Row="4"/>
                    </Grid>
                </Border>
                <Border.Effect>
                    <DropShadowEffect 
                      Color="{Binding RelativeSource={RelativeSource AncestorType=Border}, 
                      Path=BorderBrush.Color}"
                      ShadowDepth="0"
                      BlurRadius="20"
                      Opacity="0.4"/>
                </Border.Effect>
            </Border>

        </DataTemplate>
        <DataTemplate x:Key="DegreeAshCapture">
            <Border x:Name="ExternalBorder" 
             Margin="10" 
             CornerRadius="25" 
             BorderBrush="{Binding}" 
             Opacity="0.9" 
             Background="Transparent"  
             BorderThickness="4">
            <Border Background="#3A4149" Margin="3" CornerRadius="20">
            <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.7*" />
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" 
                       Grid.ColumnSpan="2" 
                       Orientation="Horizontal" 
                       Margin="5 15 10 0" 
                       VerticalAlignment="Top"  
                       HorizontalAlignment="Stretch">
                            <TextBlock TextAlignment="Left" 
                          HorizontalAlignment="Left" 
                          Foreground="#DCE0E4" 
                          Text="Топливо: " 
                          FontSize="12"
                          FontStyle="Italic"
                          FontWeight="Bold"
                          TextWrapping="Wrap" 
                          FontFamily="Century Gothic"/>
                            <TextBlock Name="Fuel" 
                          TextAlignment="Left" 
                          HorizontalAlignment="Left" 
                          Foreground="#DCE0E4" 
                          FontSize="14"
                          FontStyle="Italic"
                          TextWrapping="Wrap" 
                          FontFamily="Century Gothic"/>
                        </StackPanel>
                        <Border x:Name="InternalBorder" 
                   VerticalAlignment="Bottom" 
                   HorizontalAlignment="Stretch" 
                   Height="5" 
                   CornerRadius="2" 
                   Grid.Row="1" 
                   Grid.ColumnSpan="2" 
                   Margin="5 0 5 5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0"/>
                                    <GradientStop Color="#3A4149" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Style="{StaticResource TextBlockForm}" 
              Grid.Column="0" 
              Grid.Row="2" 
              Text="Степень золоулавливания:">
                        </TextBlock>
                        <TextBox Name="FirstField" Style="{StaticResource TextBoxUniformStyle}"
                                Grid.Column="2" Margin="10,5,10,5" IsReadOnly="True"
                                Grid.Row="2"/>
                    </Grid>
                </Border>
                <Border.Effect>
                    <DropShadowEffect 
               Color="{Binding RelativeSource={RelativeSource AncestorType=Border}, 
               Path=BorderBrush.Color}"
               ShadowDepth="0"
               BlurRadius="20"
               Opacity="0.4"/>
                </Border.Effect>
            </Border>

        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Border Background="#212529" 
                BorderBrush="#3A4149" 
                BorderThickness="5" 
                CornerRadius="8,8,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.RowSpan="4" Grid.ColumnSpan="3" 
                    Margin="0 0 0 50" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    MaxHeight="900" 
                    MaxWidth="900" 
                    Opacity="0.5"
                    Source="/Resources/Images/charts_page.png" 
                    Stretch="Uniform"/>
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="20">
                        <Border Background="#373E46" Margin="10" MaxHeight="400" CornerRadius="25" MaxWidth="1500">
                            <Grid Margin="10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <TextBlock Foreground="#DCE0E4" 
                                                   Text="" 
                                                   FontSize="20" 
                                                   TextWrapping="Wrap" 
                                                   FontFamily="/Resources/Fonts/#Raleway SemiBold">

                                        </TextBlock>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Grid.Column="1" Grid.Row="1">
                        <Border x:Name="HeaderCalculate" 
                                Background="#FF0BCDFF" 
                                Height="50" 
                                Width="150" 
                                CornerRadius="25"
                                Visibility="Visible">
                            <TextBlock TextAlignment="Center" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       Foreground="Black" 
                                       Text="К РАСЧЕТУ" 
                                       FontSize="20" 
                                       TextWrapping="NoWrap" 
                                       FontFamily="Century Gothic"/>
                        </Border>
                        <Grid Height="200" Name="GridLoad" Visibility="Collapsed"
                             Width="200"
                             VerticalAlignment="Top"
                             HorizontalAlignment="Center">
                            <Image x:Name="ProccessCalculateImage" 
                                   Height="140" 
                                   Visibility="Visible"
                                   Width="140"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Source="{StaticResource Dial_Image}"
                                   Stretch="Uniform"/>
                            <Ellipse Height="160"
                                 Width="160"
                                 Opacity="0.7"
                                 Stroke="#212529"
                                 StrokeThickness="15"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center" />
                            <Ellipse Height="100"
                                 Width="100"
                                 Stroke="#4D4D4D"
                                 StrokeThickness="10"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center" />
                            <TextBlock x:Name="TimerLabel"
                                        Foreground="#FEF200"
                                        Height="60"
                                        Width="60"
                                        FontSize="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        TextAlignment="Center"
                                        Margin="0,10,0,0">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="30"
                                           ShadowDepth="2"
                                           Direction="-90"
                                           Color="#FEF200" />
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Name="LoadText"
                            Foreground="#FFFFFF"
                            Height="16"
                            Width="150"
                            FontSize="10"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            Margin="0,40,0,0" />

                        </Grid>
                        <ToggleButton x:Name="StartButtonCalculate" 
                                      Margin="10"
                                      Height="50"
                                      Width="50"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Top"
                                      Click="Start_Click"
                                      Style="{StaticResource PlayBtn_Style}"
                                      IsChecked="False">
                            <ToggleButton.CommandParameter>
                                <MultiBinding Converter="{StaticResource MultiParameterConverter}">
                                    <Binding ElementName="HeaderCalculate"/>
                                    <Binding ElementName="GridLoad"/>
                                    <Binding ElementName="StartButtonCalculate"/>
                                </MultiBinding>
                            </ToggleButton.CommandParameter>
                        </ToggleButton>
                    </StackPanel>
                    <telerik:RadGridView  Name="resultsGrid" GroupRenderMode="Flat" Grid.Row="2" Grid.ColumnSpan="3"
                       Margin="20"
                       Height="Auto"
                       VerticalAlignment="Top"
                       AutoGenerateColumns="False"
                       ItemsSource="{Binding Results, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, IsAsync=True}" 
                       IsReadOnly="True"
                       RowIndicatorVisibility="Collapsed"
                       DataLoadMode="Asynchronous"
                       NewRowPosition="Bottom"
                       ShowColumnHeaders="True">
                        <telerik:RadGridView.Columns>

                            <telerik:GridViewDataColumn Header="Расчитываемое топливо"
							DataMemberBinding="{Binding UseFuel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, IsAsync=True}" />
                         
                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
